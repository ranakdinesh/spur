package main

import (
	"context"
	"net/http"
	"os"
	"os/signal"
	"strings"
	"syscall"
	"time"

	"github.com/go-chi/chi/v5"

	"github.com/ranakdinesh/spur/config/configx"
	"github.com/ranakdinesh/spur/httpserver"
	"github.com/ranakdinesh/spur/logger"
	{{- if .WithDB }}
	"github.com/jackc/pgx/v5/pgxpool"
	"github.com/ranakdinesh/spur/database/pgxkit"
	{{- end }}
	{{- if .WithRedis }}
	"github.com/redis/go-redis/v9"
	"github.com/ranakdinesh/spur/redis/rediskit"
	{{- end }}
	{{- if .WithAuth }}
	"github.com/ranakdinesh/spur/auth/authclient"
	{{- end }}
)

type AppConfig struct {
	AppEnv                string        `env:"APP_ENV" default:"development"`
	HTTPAddr              string        `env:"HTTP_ADDR" default:":8080"`
	ReadTimeout           time.Duration `env:"HTTP_READ_TIMEOUT" default:"15s"`
	WriteTimeout          time.Duration `env:"HTTP_WRITE_TIMEOUT" default:"30s"`
	IdleTimeout           time.Duration `env:"HTTP_IDLE_TIMEOUT" default:"60s"`
	MaxBodyBytes          int64         `env:"HTTP_MAX_BODY_BYTES" default:"10485760"`
	EnableCORS            bool          `env:"HTTP_ENABLE_CORS" default:"true"`
	EnableSecurityHeaders bool          `env:"HTTP_ENABLE_SECURITY_HEADERS" default:"true"`
	CORSAllowedOrigins    []string      `env:"CORS_ALLOWED_ORIGINS" default:"*" split:","`
	{{- if .WithDB }}
	DatabaseURL           string        `env:"DATABASE_URL"`
	{{- end }}
	{{- if .WithRedis }}
	RedisAddr             string        `env:"REDIS_ADDR"`
	{{- end }}
	{{- if .WithAuth }}
	OAuthIssuer           string        `env:"OAUTH_ISSUER"`
	OAuthAudience         string        `env:"OAUTH_AUDIENCE"`
	OAuthJWKSURL          string        `env:"OAUTH_JWKS_URL"`
	{{- end }}
	LogServiceURL         string        `env:"LOG_SVC_URL"`
	LogServiceKey         string        `env:"LOG_SVC_API_KEY"`
}

func main() {
	// Load config
	cfg := AppConfig{}
	configx.MustLoad(&cfg)

	// Logger
	prod := strings.ToLower(cfg.AppEnv) == "production"
	log := logger.NewWithOptions(logger.Options{
		Dev:            !prod,
		EnableHTTPSink: prod && cfg.LogServiceURL != "",
		HTTPURL:        cfg.LogServiceURL,
		HTTPAPIKey:     cfg.LogServiceKey,
		HTTPTimeout:    time.Second,
		Buffer:         2048,
	})

	// Optional dependencies
	{{- if .WithDB }}
	var pool *pgxpool.Pool
	if cfg.DatabaseURL != "" {
		p, err := pgxkit.NewPool(context.Background(), pgxkit.Options{DatabaseURL: cfg.DatabaseURL})
		if err != nil {
			log.Error(context.Background()).Err(err).Msg("db connect failed")
		} else {
			pool = p
			defer pool.Close()
			log.Info(context.Background()).Msg("db connected")
		}
	}
	{{- end }}

	{{- if .WithRedis }}
	var rdb *redis.Client
	if cfg.RedisAddr != "" {
		rr, err := rediskit.NewClient(context.Background(), rediskit.Options{Addr: cfg.RedisAddr})
		if err != nil {
			log.Error(context.Background()).Err(err).Msg("redis connect failed")
		} else {
			rdb = rr
			defer rdb.Close()
			log.Info(context.Background()).Msg("redis connected")
		}
	}
	{{- end }}

	{{- if .WithAuth }}
	var v *authclient.Validator
	if cfg.OAuthIssuer != "" || cfg.OAuthJWKSURL != "" {
		vv, err := authclient.NewValidator(context.Background(), authclient.Options{
			Issuer:   cfg.OAuthIssuer,
			Audience: []string{cfg.OAuthAudience},
			JWKSURL:  cfg.OAuthJWKSURL,
		})
		if err != nil {
			log.Error(context.Background()).Err(err).Msg("auth validator init failed")
		} else {
			v = vv
			defer v.Close()
		}
	}
	{{- end }}

	// HTTP server
	srv := httpserver.NewServer(httpserver.Options{
		Addr:                  cfg.HTTPAddr,
		ReadTimeout:           cfg.ReadTimeout,
		WriteTimeout:          cfg.WriteTimeout,
		IdleTimeout:           cfg.IdleTimeout,
		MaxBodyBytes:          cfg.MaxBodyBytes,
		EnableCORS:            cfg.EnableCORS,
		EnableSecurityHeaders: cfg.EnableSecurityHeaders,
		AllowedOrigins:        cfg.CORSAllowedOrigins,
	}, log, func(r chi.Router) {
		// public route
		r.Get("/healthz", func(w http.ResponseWriter, _ *http.Request) { w.WriteHeader(200) })

		{{- if .WithRedis }}
		if rdb != nil {
			r.Use(rediskit.IdempotencyMiddleware(rdb, rediskit.IdemOptions{
				TTL:        10 * time.Minute,
				HeaderName: "Idempotency-Key",
				MaxBody:    256 << 10,
			}))
		}
		{{- end }}

		{{- if .WithAuth }}
		// protected example
		r.Group(func(pr chi.Router) {
			pr.Use(authclient.HTTPAuth(v, authclient.Options{
				Issuer:       cfg.OAuthIssuer,
				Audience:     []string{cfg.OAuthAudience},
				APIKeyHeader: "X-API-Key",
				APIKeyValue:  "",
			}, log))
			pr.Get("/me", func(w http.ResponseWriter, r *http.Request) {
				sub, _ := authclient.SubjectFrom(r.Context())
				w.Write([]byte("hello " + sub))
			})
		})
		{{- end }}
	})

	// Lifecycle
	ctx, stop := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer stop()

	if err := srv.Start(ctx); err != nil {
		log.Error(ctx).Err(err).Msg("http server exited")
		os.Exit(1)
	}

	{{- _ = .WithGRPC -}} // placeholder for future "mixed" template
}
