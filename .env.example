APP_NAME=spur-example
APP_ENV=development
HTTP_ENABLE=true
HTTP_PORT=8080
HTTP_ENABLE_CORS=true

GRPC_ENABLE=true
GRPC_PORT=9090

LOG_LEVEL=debug
LOGGER_SERVICE_URL=http://localhost:8088/log

PG_DSN=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
ENABLE_POSTGRES= false
ENABLE_REDIS=false
REDIS_ADDR=localhost:6379
REDIS_DB=0
REDIS_PASSWORD=
